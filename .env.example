# Copy this file to .env and fill in your values.
# NEVER commit .env to Git — it is listed in .gitignore.

# Generate a new secret key by running:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# Set to True for local development only. Always False in production.
DEBUG=True

# Space-separated list of allowed hostnames
ALLOWED_HOSTS=localhost 127.0.0.1

# PostgreSQL connection string.
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE
#
# Windows example (default PostgreSQL install):
#   DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/fittrack
#
# Mac/Linux example:
#   DATABASE_URL=postgresql://localhost/fittrack
#
# Heroku sets DATABASE_URL automatically — do NOT set it manually on Heroku.
DATABASE_URL=postgresql://postgres:yourpassword@127.0.0.1:5432/fittrack

# CSRF trusted origins — required on Heroku so forms work over HTTPS.
# Add your Heroku app URL here (with https://).
# Leave blank for local development.
# Example: CSRF_TRUSTED_ORIGINS=https://your-app-name.herokuapp.com
CSRF_TRUSTED_ORIGINS=
