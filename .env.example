# Copy this file to .env and fill in your values.
# NEVER commit .env to Git — it is listed in .gitignore.

# Generate a new secret key by running:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY= your-secret-key-here

# Set to True for local development only. Always False in production.
DEBUG=True

# Space-separated list of allowed hostnames
ALLOWED_HOSTS=localhost 127.0.0.1

# PostgreSQL connection string.
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE
#
# Windows example (default PostgreSQL install):
#   DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/fittrack
#
# Mac/Linux example:
#   DATABASE_URL=postgresql://localhost/fittrack
#
# Heroku sets DATABASE_URL automatically — do NOT set it manually on Heroku.
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/fittrack

# CSRF trusted origins — required on Heroku so forms work over HTTPS.
# Add your Heroku app URL here (with https://).
# Leave blank for local development.
# Example: CSRF_TRUSTED_ORIGINS=https://your-app-name.herokuapp.com
CSRF_TRUSTED_ORIGINS=

# ── Email (password reset) ─────────────────────────────────────────────────
# For local development the console backend prints emails to the terminal.
# No further config needed locally — leave these blank or omit them.
#
# For production (Heroku), set these via: heroku config:set KEY=value
#
# Option A — Resend (recommended, free tier: 3,000 emails/month)
#   1. Sign up at https://resend.com and create an API key
#   2. Either verify your own domain OR use onboarding@resend.dev for testing
#   EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
#   EMAIL_HOST=smtp.resend.com
#   EMAIL_PORT=587
#   EMAIL_HOST_USER=resend
#   EMAIL_HOST_PASSWORD=re_your_api_key_here
#   DEFAULT_FROM_EMAIL=noreply@yourdomain.com   # or onboarding@resend.dev for testing
#
# Option B — any other SMTP provider (Mailgun, Brevo, AWS SES, etc.)
#   EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
#   EMAIL_HOST=smtp.your-provider.com
#   EMAIL_PORT=587
#   EMAIL_HOST_USER=your-smtp-username
#   EMAIL_HOST_PASSWORD=your-smtp-password
#   DEFAULT_FROM_EMAIL=noreply@yourdomain.com
#
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@fittrack.app
